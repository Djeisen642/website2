{
  "name": "website2",
  "version": "1.0.0",
  "description": "A website for Jason S.",
  "main": "index.js",
  "repository": "git@github.com:Djeisen642/website2.git",
  "author": "Jason <jasonssuttles@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "lint:js": "echo \"ESLINT --\" && eslint .",
    "lint:style": "echo \"STYLELINT --\" && stylelint \"**/*.{vue,scss,css}\" --ignore-path .gitignore",
    "lint": "bun run lint:js && bun run lint:style && bun run check:types && bun run nuxt:types",
    "check:types": "echo \"TSC --\" && tsgo --noEmit",
    "nuxt:types": "nuxt typecheck",
    "postinstall": "nuxt prepare && husky",
    "postpack": "pinst --enable",
    "prepack": "pinst --disable",
    "preview": "nuxt preview",
    "start": "bun run dev",
    "up-i": "bun update --interactive",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "@firebase/app": "0.14.9",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/test-utils": "4.0.0",
    "@nuxtjs/device": "4.0.0",
    "@pinia/testing": "1.0.3",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/eslint": "9.6.1",
    "@types/jest-axe": "3.5.9",
    "@types/node": "25.3.5",
    "@types/uuid": "11.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "@vue/test-utils": "2.4.6",
    "eslint": "10.0.3",
    "eslint-plugin-vuejs-accessibility": "2.5.0",
    "firebase-tools": "15.9.0",
    "globals": "17.4.0",
    "happy-dom": "20.8.3",
    "husky": "9.1.7",
    "node-fetch": "3.3.2",
    "nuxt": "4.3.1",
    "pinia": "3.0.4",
    "pinst": "3.0.0",
    "postcss": "8.5.8",
    "postcss-html": "1.8.1",
    "sass-embedded": "1.97.3",
    "stylelint": "17.4.0",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-config-standard-scss": "17.0.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-vuetify": "2.1.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/core": "^14.1.0",
    "@vueuse/nuxt": "^14.1.0",
    "firebase": "^12.8.0",
    "highlight.js": "^11.11.1",
    "prettier": "^3.8.0",
    "quill": "^2.0.3",
    "uuid": "^13.0.0",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4",
    "vuetify": "3.12.2",
    "web-vitals": "^5.1.0"
  },
  "engines": {
    "bun": "^1.3.5"
  }
}
